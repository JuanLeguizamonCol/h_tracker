# Frontend environment variables — copy to .env for local (non-Docker) dev.
#
# Auth is username/password → JWT, handled by the backend. There is no MSAL /
# Entra ID integration in the frontend.
#
# Backend URL:
#   - Production (Azure): injected at RUNTIME via /config.js (window.__ENV__.API_URL)
#     from the container's BACKEND_URL env var — NOT set here, not baked at build.
#   - Local `vite dev`: set VITE_API_URL to your backend, or leave it empty to use
#     the relative `/api` path (proxied to the backend).
VITE_API_URL=http://localhost:8001
