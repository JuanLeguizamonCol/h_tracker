# Frontend environment variables — copy to .env and fill in values
#
# Auth mode
# "azure"  — real Microsoft Entra ID login via MSAL (default for all environments)
# "mock"   — bypass authentication for local development without Docker
VITE_AUTH_MODE=azure

# ── Azure Entra ID — SPA App Registration ──────────────────────────────────────
# Client ID of the SPA app registration (hours-tracker front).
# This is a PUBLIC client — no secret required (PKCE flow).
VITE_AZURE_CLIENT_ID=b44bcf9e-cc38-4542-82b9-e9447a45a7ec

# Tenant ID of your Entra ID directory
VITE_AZURE_TENANT_ID=9a347a67-e3c3-4de7-9c88-449af6f6c092

# Redirect URI registered in the SPA app registration.
# Must exactly match one of the URIs registered in Azure Portal → Authentication → SPA.
# Local dev:   http://localhost:3000
# Production:  https://your-app-domain.com
VITE_AZURE_REDIRECT_URI=http://localhost:3000

# API scope to request when acquiring tokens.
# Must match the scope exposed by the backend API app registration.
VITE_AZURE_API_SCOPE=api://6cda0fcc-09b3-4173-b6cc-07df8bf2b82b/user_impersonation
