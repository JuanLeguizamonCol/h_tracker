# H_Tracker — environment variable reference (BACKEND)
# Copy to Backend/.env for local dev, or to azure.env for docker-compose.
# NEVER commit files containing real secrets.
#
# Docker usage:
#   docker-compose --env-file azure.env up -d
# Local backend (non-Docker):
#   cp .env.example Backend/.env   (then edit as needed)
#
# Auth is username/password → JWT (HS256), handled entirely by the FastAPI
# backend. There is no Entra ID / MSAL integration.

# ── Runtime environment ───────────────────────────────────────────────────────
ENV=dev
SQL_ECHO=false

# ── Database ──────────────────────────────────────────────────────────────────
# Local (non-Docker): postgres is mapped to host port 5433 by docker-compose.
# Inside Docker Compose: use the service name and internal port 5432.
DATABASE_URL=postgresql://hours_user:hours_pass@localhost:5433/hours_tracker

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. In Azure this is set to the frontend FQDN.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Signing key for access tokens. Generate a strong value: openssl rand -base64 48
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Initial admin (created idempotently at startup) ───────────────────────────
# If unset, no admin is created. must_change_password is forced on first login.
ADMIN_EMAIL=jleguizamon@impactpoint.com
ADMIN_PASSWORD=
ADMIN_NAME=

# ── Self-registration ─────────────────────────────────────────────────────────
# Comma-separated email domains allowed to register. Empty string disables it.
ALLOWED_EMAIL_DOMAINS=impactpoint.com

# ── File uploads ──────────────────────────────────────────────────────────────
# Local filesystem fallback path. When AZURE_STORAGE_CONNECTION_STRING is set,
# invoice attachments go to Blob Storage instead (Container Apps FS is ephemeral).
UPLOAD_DIR=/app/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=invoice-attachments
AZURE_STORAGE_SAS_TTL_MINUTES=60

# ── Expensify Partner API ─────────────────────────────────────────────────────
EXPENSIFY_PARTNER_USER_ID=
EXPENSIFY_PARTNER_USER_SECRET=

# ── FreshSales CRM API ────────────────────────────────────────────────────────
FRESHSALES_DOMAIN=yourcompany
FRESHSALES_API_KEY=your_freshsales_api_key_here

# ── Exchange rates ────────────────────────────────────────────────────────────
COP_TO_USD_RATE=4200
EUR_TO_USD_RATE=1.08
